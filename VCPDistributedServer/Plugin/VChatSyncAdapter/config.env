# -------------------------------------------------------------------
# [VChat Sync Adapter]
# -------------------------------------------------------------------
# 这是 VCPDistributedServer/Plugin/VChatSyncAdapter 的独立配置文件。
# 源码会优先读取本文件；若本文件某项留空，再回退到宿主注入的 pluginConfig。
# 因此推荐把 Adapter 自己的同步参数集中维护在这里，减少对宿主配置注入的依赖。
#
# 同步中心 URL 必须填写到 VCPToolBox 插件实际挂载前缀，例如：
#   http://100.100.50.10:6005/api/plugins/VChatSyncCenter
#
# VCHAT_SYNC_KEY 必须与 VCPToolBox 侧 VChatSyncCenter 的 VCHAT_SYNC_KEY 保持一致。
# Adapter 本地 bootstrap/status/conflicts 管理接口也复用这把 key 做鉴权。

# 是否启用 Adapter。false 时只注册管理路由，不启动扫描/监听/拉取循环。
VCHAT_ADAPTER_ENABLED=true

# 当前设备同步模式；首次部署建议保持 uninitialized，再通过 bootstrap API 初始化。
VCHAT_ADAPTER_MODE=uninitialized

# VChat AppData 路径。相对路径基于 VCPDistributedServer 根目录解析。
# 默认 ../AppData 即：VCPDistributedServer/../AppData
VCHAT_APPDATA_PATH=../AppData

# 同步中心 API 前缀。必须指向 VCPToolBox 宿主上的 VChatSyncCenter 挂载地址。
VCHAT_SYNC_CENTER_URL=http://100.100.50.10:6005/api/plugins/VChatSyncCenter

# 同步密钥。必须与中心侧一致。请改成你自己的高强度随机字符串，不要长期使用示例值。
VCHAT_SYNC_KEY=258456

# 设备 ID。留空时源码会自动生成：hostname-username（并做安全字符替换）。
VCHAT_DEVICE_ID=fuwuqi

# 设备显示名。留空时默认取当前机器 hostname。
VCHAT_DEVICE_NAME=服务器

# 文件监听防抖时间，单位毫秒。
VCHAT_WATCH_DEBOUNCE_MS=700

# 离线队列重试/冲刷周期，单位毫秒。
VCHAT_QUEUE_INTERVAL_MS=5000

# 从同步中心拉取变更的轮询周期，单位毫秒。
VCHAT_PULL_INTERVAL_MS=15000

# 附件 multipart 上传阈值，单位字节；超过该大小时中心客户端会使用 multipart/form-data 上传。
# 默认 8388608 即 8MB。
VCHAT_ATTACHMENT_MULTIPART_THRESHOLD_BYTES=8388608

# 是否启用 latest-seq WebSocket 通知；即使关闭，REST 轮询仍会兜底。
VCHAT_SYNC_ENABLE_WS=true

# 启动时自动 bootstrap 策略。manual 表示不自动初始化。
# 可选值按当前源码能力通常包括：manual / bootstrap_primary / join_existing / merge_existing
VCHAT_BOOTSTRAP_MODE=manual

# 当前发布/能力分层标记，保留给模式策略与灰度控制使用。
VCHAT_RELEASE_MODE=mvp-local-only

# 调试日志开关。
DebugMode=false
