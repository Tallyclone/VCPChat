  "6682e375-2107-4598-ba18-b7013cafff5e:17": [
    {
      "op": "update",
      "notebookId": "notebook-1779630238954_yvjompk0a",
      "previousNote": "2026-05-24 investigation: renderer currently only intercepts DESKTOP_PUSH / DESKTOP_PUSH_END. There is no DESKTOP_WIDGET parser chain in streamManager, messageRenderer, or DesktopRemote plugin. So any <<<[DESKTOP_WIDGET]>>> block is treated as ordinary chat text and will render verbatim unless new parsing/dispatch logic is added."
    },
